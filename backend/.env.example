# Backend environment variables
# Copy this to .env and fill in real values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/meditriage?appName=Cluster0

# JWT secret — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_secret

# URL of the deployed Python AI server
PYTHON_AI_URL=https://your-python-server.onrender.com

# Email (Gmail App Password — see: myaccount.google.com/apppasswords)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# Frontend URL (used to build the intake link in emails)
APP_URL=http://localhost:5173
